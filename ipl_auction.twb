      <aliases enabled='yes' />
      <column caption='Price in Rs' datatype='integer' name='[Calculation_1527001767847972865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(REPLACE([Price in rs], &quot;,&quot;, &quot;&quot;))' />
      </column>
      <column caption='Overseas Player %' datatype='real' name='[Calculation_1527001767849037826]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Nationality]=&apos;Overseas&apos; THEN [Name] END)/COUNT([Name])' />
      </column>
      <column caption='Highest Bid' datatype='integer' name='[Calculation_1527001767849680899]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Calculation_1527001767847972865])' />
      </column>
      <column caption='Auction Year' datatype='date' datatype-customized='true' name='[Calculation_1527001767851859972]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;yyyy&quot;, MID([Path], FIND([Path], &quot;IPL_Auction_&quot;) + 12, 4) )) ' />
      </column>
      <column caption='avg bid' datatype='real' name='[Calculation_1527001767864078341]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1527001767847972865])' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_1527001767865057286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_1527001767847972865]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
